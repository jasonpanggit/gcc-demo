# ==============================================================================
# Terraform .gitignore
# ==============================================================================

# Terraform state files - contain sensitive data and infrastructure state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files containing sensitive data
credentials.tfvars
terraform.tfvars # for testing 

# Terraform plan files - may contain sensitive data
*.tfplan
*.tfplan.*

# Terraform crash log files
crash.log
crash.*.log

# Terraform RC files - may contain sensitive provider configurations
.terraformrc
terraform.rc

# Terraform directories
.terraform/
.terraform.lock.hcl

# Override files - often contain local/sensitive configurations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files - may contain sensitive data
.terraformrc
terraform.rc

# Environment-specific files
.env
.env.example
.env.local
.env.*.local

# IDE and editor files
.vscode/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log

# backup
backup/
*.backup
*.bak

# docs
docs/

# tests - ignore root-level tests directory only
# (app/agentic/eol/tests/ is tracked - contains critical test infrastructure)
/tests/

# Zip files
*.zip

# Azure
.azure

# Virtual environments
.venv/

# test
.pytest_cache/
__pycache__/
.coverage
htmlcov/

# Project TODO file
# Ignore TODO.md in any directory
TODO.md

# Ignore appsettings.json files but keep the example
# ignore any appsettings*.json
appsettings*.json
# except the example file which should remain tracked
!appsettings.json.example

# litellm
litellm/**

# machine-specific duplicate filenames
*-Jason Pang Mac Mini*
*-Jason’s MacBook Air*

# claude code related files - ignore all .claude directories
.claude/**
**/.claude/
.planning/**
**/.planning/
CLAUDE.md
tasks/

# github - ignore all .github directories
.github/**
**/.github/

# EXCEPT: Track CI workflow for MCP tool selection tests
!.github/workflows/test-tool-selection.yml

# playwright/firecrawl
.playwright-mcp/**
.firecrawl/**

# errors
errors/** 