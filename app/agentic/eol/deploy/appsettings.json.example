{
  "Azure": {
    "SubscriptionId": "your-subscription-id",
    "TenantId": "your-tenant-id",
    "ResourceGroup": "your-resource-group",
    "Location": "australiaeast"
  },
  "Deployment": {
    "ContainerApp": {
      "Name": "your-container-app-name",
      "Environment": "your-container-app-environment",
      "Url": "https://your-app.region.azurecontainerapps.io/"
    },
    "ContainerRegistry": {
      "Name": "your-acr-name",
      "ImageName": "eol-app",
      "DefaultTag": "latest"
    }
  },
  "ServicePrincipal": {
    "_comment": "SPN for Azure CLI execution",
    "ClientId": "your-service-principal-client-id",
    "ClientSecret": "your-service-principal-secret",
    "UseServicePrincipal": true
  },
  "ManagedIdentity": {
    "_comment": "System Assigned Managed Identity for the Container App",
    "ClientId": "your-managed-identity-client-id"
  },
  "AzureServices": {
    "OpenAI": {
      "Endpoint": "https://your-openai.openai.azure.com/",
      "Deployment": "gpt-4o-mini",
      "ApiVersion": "2024-08-01-preview",
      "EmbeddingDeployment": "text-embedding-3-small"
    },
    "CosmosDB": {
      "Endpoint": "https://your-cosmos.documents.azure.com:443/",
      "Database": "your-database",
      "Container": "your-container"
    },
    "LogAnalytics": {
      "WorkspaceId": "your-log-analytics-workspace-id"
    },
    "AIFoundry": {
      "ProjectName": "your-ai-project-name",
      "Endpoint": "https://your-ai-foundry.cognitiveservices.azure.com/",
      "ProjectEndpoint": "https://your-ai-foundry.services.ai.azure.com/api/projects/your-ai-project-name",
      "SREAgentName": "gccsreagent",
      "SREAgentId": "your-sre-agent-id-optional",
      "SREEnabled": "true",
      "Comment": "Azure AI Agent Service configuration for Azure AI SRE agent integration"
    },
    "Kusto": {
      "ClusterUri": "https://data-explorer.azure.com",
      "Database": "ARG",
      "Description": "Azure Resource Graph endpoint for KQL queries"
    },
    "SREPerformance": {
      "ToolCallTimeout": 30,
      "TotalTimeout": 120,
      "ParallelToolLimit": 5,
      "CacheTTL": 300,
      "ConnectionPoolSize": 10,
      "EnableStreaming": true,
      "EnableCache": true,
      "DisableFormatResponse": true,
      "HybridFormattingEnabled": true,
      "HybridTimeoutSeconds": 15,
      "HybridMaxTokens": 240,
      "Comment": "Performance tuning for SRE agent integration"
    }
  },
  "TeamsBot": {
    "AppId": "your-teams-bot-app-id",
    "AppPassword": "your-teams-bot-app-password",
    "_comment": "Microsoft Teams Bot credentials for SRE notifications"
  },
  "AppSettings": {
    "WEBSITES_PORT": "8000",
    "PYTHONUNBUFFERED": "1",
    "DEBUG_MODE": "true",
    "ENVIRONMENT": "production",
    "CONTAINER_MODE": "true"
  },
  "RoutingTelemetry": {
    "_comment": "Phase 4: Production routing monitoring and validation",
    "ROUTING_TELEMETRY_ENABLED": "true",
    "ROUTING_TELEMETRY_LOG_DIR": "/mnt/routing_logs",
    "ROUTING_TELEMETRY_SAMPLE_RATE": "1.0",
    "Description": "Captures routing decisions for Phase 3 accuracy validation. Set ENABLED=false to disable. SAMPLE_RATE controls % of queries logged (1.0=100%, 0.5=50%)."
  },
  "McpSettings": {
    "AzureCliExecutorEnabled": false
  }
}