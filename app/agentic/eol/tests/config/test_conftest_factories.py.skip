"""
Tests that validate conftest.py network factory helpers and fixtures.

Covers:
- factory_make_nsg
- factory_make_vnet
- factory_make_subnet
- factory_make_routetable
- factory_make_nic
- factory_make_public_ip
- factory_make_vnet_peering
- mock_network_client fixture
- mock_network_mcp_client fixture
- mock_resourcegraph_client fixture

Created: 2026-02-27 (Phase 1, Task 14 - Network Agent Enhancement)
"""

import pytest
from unittest.mock import MagicMock, AsyncMock

# Import factory helpers directly from conftest (they are module-level functions)
from conftest import (
    factory_make_nsg,
    factory_make_vnet,
    factory_make_subnet,
    factory_make_routetable,
    factory_make_nic,
    factory_make_public_ip,
    factory_make_vnet_peering,
)


# =============================================================================
# factory_make_nsg
# =============================================================================

class TestFactoryMakeNsg:
    def test_basic_attributes(self):
        nsg = factory_make_nsg("my-nsg", "/subs/test/nsg", "eastus")
        assert nsg.name == "my-nsg"
        assert nsg.id == "/subs/test/nsg"
        assert nsg.location == "eastus"

    def test_default_rule_created(self):
        nsg = factory_make_nsg("my-nsg", "/subs/test/nsg", "eastus")
        assert len(nsg.security_rules) == 1
        rule = nsg.security_rules[0]
        assert rule.name == "allow-https"
        assert rule.priority == 100
        assert rule.direction == "Inbound"
        assert rule.access == "Allow"
        assert rule.protocol == "Tcp"
        assert rule.destination_port_range == "443"

    def test_custom_rules(self):
        custom_rules = [
            {
                "name": "deny-all",
                "priority": 4096,
                "direction": "Inbound",
                "access": "Deny",
                "protocol": "*",
                "source_address_prefix": "*",
                "destination_address_prefix": "*",
                "source_port_range": "*",
                "destination_port_range": "*",
            },
            {
                "name": "allow-ssh",
                "priority": 200,
                "direction": "Inbound",
                "access": "Allow",
                "protocol": "Tcp",
                "source_address_prefix": "10.0.0.0/8",
                "destination_address_prefix": "*",
                "source_port_range": "*",
                "destination_port_range": "22",
            },
        ]
        nsg = factory_make_nsg("my-nsg", "/subs/test/nsg", "eastus", rules_list=custom_rules)
        assert len(nsg.security_rules) == 2
        assert nsg.security_rules[0].name == "deny-all"
        assert nsg.security_rules[0].priority == 4096
        assert nsg.security_rules[1].name == "allow-ssh"
        assert nsg.security_rules[1].destination_port_range == "22"

    def test_nested_rule_attributes_accessible(self):
        nsg = factory_make_nsg("my-nsg", "/subs/test/nsg", "eastus")
        rule = nsg.security_rules[0]
        # Verify all required rule attributes exist
        assert hasattr(rule, "name")
        assert hasattr(rule, "priority")
        assert hasattr(rule, "direction")
        assert hasattr(rule, "access")
        assert hasattr(rule, "protocol")
        assert hasattr(rule, "source_address_prefix")
        assert hasattr(rule, "destination_address_prefix")
        assert hasattr(rule, "source_port_range")
        assert hasattr(rule, "destination_port_range")


# =============================================================================
# factory_make_vnet
# =============================================================================

class TestFactoryMakeVnet:
    def test_basic_attributes(self):
        vnet = factory_make_vnet("hub-vnet", ["10.0.0.0/16"], "eastus")
        assert vnet.name == "hub-vnet"
        assert vnet.location == "eastus"
        assert "hub-vnet" in vnet.id

    def test_address_space(self):
        vnet = factory_make_vnet("hub-vnet", ["10.0.0.0/16", "172.16.0.0/12"], "westus2")
        assert vnet.address_space.address_prefixes == ["10.0.0.0/16", "172.16.0.0/12"]

    def test_default_dns_servers(self):
        vnet = factory_make_vnet("hub-vnet", ["10.0.0.0/16"], "eastus")
        assert "168.63.129.16" in vnet.dhcp_options.dns_servers

    def test_default_subnets_empty(self):
        vnet = factory_make_vnet("hub-vnet", ["10.0.0.0/16"], "eastus")
        assert vnet.subnets == []

    def test_custom_subnets(self):
        subnet = factory_make_subnet("web", "10.0.1.0/24")
        vnet = factory_make_vnet("hub-vnet", ["10.0.0.0/16"], "eastus", subnets=[subnet])
        assert len(vnet.subnets) == 1
        assert vnet.subnets[0].name == "web"


# =============================================================================
# factory_make_subnet
# =============================================================================

class TestFactoryMakeSubnet:
    def test_basic_attributes(self):
        subnet = factory_make_subnet("default", "10.0.0.0/24")
        assert subnet.name == "default"
        assert subnet.address_prefix == "10.0.0.0/24"
        assert "default" in subnet.id

    def test_no_nsg_by_default(self):
        subnet = factory_make_subnet("default", "10.0.0.0/24")
        assert subnet.network_security_group is None

    def test_no_route_table_by_default(self):
        subnet = factory_make_subnet("default", "10.0.0.0/24")
        assert subnet.route_table is None

    def test_with_nsg(self):
        nsg = factory_make_nsg("my-nsg", "/subs/test/nsg", "eastus")
        subnet = factory_make_subnet("default", "10.0.0.0/24", nsg=nsg)
        assert subnet.network_security_group is not None
        assert subnet.network_security_group.id == nsg.id

    def test_with_route_table(self):
        rt = factory_make_routetable("my-rt")
        subnet = factory_make_subnet("default", "10.0.0.0/24", route_table=rt)
        assert subnet.route_table is not None
        assert subnet.route_table.id == rt.id

    def test_with_both_nsg_and_route_table(self):
        nsg = factory_make_nsg("my-nsg", "/subs/test/nsg", "eastus")
        rt = factory_make_routetable("my-rt")
        subnet = factory_make_subnet("default", "10.0.0.0/24", nsg=nsg, route_table=rt)
        assert subnet.network_security_group.id == nsg.id
        assert subnet.route_table.id == rt.id


# =============================================================================
# factory_make_routetable
# =============================================================================

class TestFactoryMakeRoutetable:
    def test_basic_attributes(self):
        rt = factory_make_routetable("my-rt")
        assert rt.name == "my-rt"
        assert "my-rt" in rt.id

    def test_default_route(self):
        rt = factory_make_routetable("my-rt")
        assert len(rt.routes) == 1
        route = rt.routes[0]
        assert route.name == "default-route"
        assert route.address_prefix == "0.0.0.0/0"
        assert route.next_hop_type == "VirtualAppliance"
        assert route.next_hop_ip_address == "10.0.0.4"

    def test_custom_routes(self):
        custom_routes = [
            {"name": "to-internet", "address_prefix": "0.0.0.0/0", "next_hop_type": "Internet"},
            {"name": "to-hub", "address_prefix": "10.0.0.0/8", "next_hop_type": "VirtualAppliance", "next_hop_ip_address": "10.100.0.4"},
        ]
        rt = factory_make_routetable("my-rt", routes=custom_routes)
        assert len(rt.routes) == 2
        assert rt.routes[0].next_hop_type == "Internet"
        assert rt.routes[1].next_hop_ip_address == "10.100.0.4"

    def test_route_attributes_accessible(self):
        rt = factory_make_routetable("my-rt")
        route = rt.routes[0]
        assert hasattr(route, "name")
        assert hasattr(route, "address_prefix")
        assert hasattr(route, "next_hop_type")
        assert hasattr(route, "next_hop_ip_address")


# =============================================================================
# factory_make_nic
# =============================================================================

class TestFactoryMakeNic:
    def test_basic_attributes(self):
        nic = factory_make_nic("vm-nic-01")
        assert nic.name == "vm-nic-01"
        assert "vm-nic-01" in nic.id

    def test_default_ip_config(self):
        nic = factory_make_nic("vm-nic-01")
        assert len(nic.ip_configurations) == 1
        cfg = nic.ip_configurations[0]
        assert cfg.private_ip_address == "10.0.1.4"
        assert cfg.subnet.id != ""
        assert cfg.public_ip_address is None

    def test_custom_ip_config_with_public_ip(self):
        pip = factory_make_public_ip("vm-pip-01", attached=True)
        configs = [
            {
                "private_ip_address": "10.0.2.10",
                "subnet_id": "/subs/test/subnet/web",
                "public_ip_id": pip.id,
            }
        ]
        nic = factory_make_nic("vm-nic-01", ip_configs=configs)
        cfg = nic.ip_configurations[0]
        assert cfg.private_ip_address == "10.0.2.10"
        assert cfg.public_ip_address.id == pip.id

    def test_ip_config_attributes_accessible(self):
        nic = factory_make_nic("vm-nic-01")
        cfg = nic.ip_configurations[0]
        assert hasattr(cfg, "private_ip_address")
        assert hasattr(cfg, "subnet")
        assert hasattr(cfg, "public_ip_address")


# =============================================================================
# factory_make_public_ip
# =============================================================================

class TestFactoryMakePublicIp:
    def test_basic_attributes(self):
        pip = factory_make_public_ip("my-pip")
        assert pip.name == "my-pip"
        assert "my-pip" in pip.id
        assert pip.public_ip_allocation_method == "Static"

    def test_unattached_by_default(self):
        pip = factory_make_public_ip("my-pip")
        assert pip.ip_configuration is None

    def test_attached(self):
        pip = factory_make_public_ip("my-pip", attached=True)
        assert pip.ip_configuration is not None
        assert pip.ip_configuration.id != ""

    def test_dynamic_allocation(self):
        pip = factory_make_public_ip("my-pip", allocation_method="Dynamic")
        assert pip.public_ip_allocation_method == "Dynamic"


# =============================================================================
# factory_make_vnet_peering
# =============================================================================

class TestFactoryMakeVnetPeering:
    def test_basic_attributes(self):
        peering = factory_make_vnet_peering(
            "hub-to-spoke", "/subs/test/vnets/spoke-vnet"
        )
        assert peering.name == "hub-to-spoke"
        assert "hub-to-spoke" in peering.id
        assert peering.remote_virtual_network.id == "/subs/test/vnets/spoke-vnet"
        assert peering.peering_state == "Connected"

    def test_custom_peering_state(self):
        peering = factory_make_vnet_peering(
            "hub-to-spoke", "/subs/test/spoke", peering_state="Disconnected"
        )
        assert peering.peering_state == "Disconnected"

    def test_gateway_transit_defaults(self):
        peering = factory_make_vnet_peering("hub-to-spoke", "/subs/test/spoke")
        assert peering.allow_gateway_transit is False
        assert peering.use_remote_gateways is False

    def test_remote_vnet_id_accessible(self):
        peering = factory_make_vnet_peering("hub-to-spoke", "/subs/test/spoke")
        assert hasattr(peering, "remote_virtual_network")
        assert hasattr(peering.remote_virtual_network, "id")


# =============================================================================
# mock_network_client fixture
# =============================================================================

class TestMockNetworkClientFixture:
    @pytest.mark.asyncio
    async def test_nsg_get(self, mock_network_client):
        nsg = await mock_network_client.network_security_groups.get("rg", "nsg")
        assert nsg.name == "test-nsg-01"
        assert nsg.location == "eastus"

    @pytest.mark.asyncio
    async def test_nsg_list_async_generator(self, mock_network_client):
        nsgs = [n async for n in mock_network_client.network_security_groups.list("rg")]
        assert len(nsgs) == 1
        assert nsgs[0].name == "test-nsg-01"

    @pytest.mark.asyncio
    async def test_vnet_get(self, mock_network_client):
        vnet = await mock_network_client.virtual_networks.get("rg", "vnet")
        assert vnet.name == "test-vnet-01"
        assert vnet.address_space.address_prefixes == ["10.0.0.0/16"]

    @pytest.mark.asyncio
    async def test_subnet_get(self, mock_network_client):
        subnet = await mock_network_client.subnets.get("rg", "vnet", "subnet")
        assert subnet.name == "default"

    @pytest.mark.asyncio
    async def test_route_table_get(self, mock_network_client):
        rt = await mock_network_client.route_tables.get("rg", "rt")
        assert rt.name == "test-rt-01"
        assert len(rt.routes) == 1

    @pytest.mark.asyncio
    async def test_nic_get(self, mock_network_client):
        nic = await mock_network_client.network_interfaces.get("rg", "nic")
        assert nic.name == "test-nic-01"

    @pytest.mark.asyncio
    async def test_public_ip_get(self, mock_network_client):
        pip = await mock_network_client.public_ip_addresses.get("rg", "pip")
        assert pip.name == "test-pip-01"
        assert pip.ip_configuration is not None

    @pytest.mark.asyncio
    async def test_peering_get(self, mock_network_client):
        peering = await mock_network_client.virtual_network_peerings.get("rg", "vnet", "peering")
        assert peering.peering_state == "Connected"
        assert peering.remote_virtual_network.id != ""

    @pytest.mark.asyncio
    async def test_begin_create_or_update(self, mock_network_client):
        poller = await mock_network_client.network_security_groups.begin_create_or_update(
            "rg", "nsg", {}
        )
        result = await poller.result()
        assert result.name == "test-nsg-01"

    @pytest.mark.asyncio
    async def test_flow_log_backwards_compatibility(self, mock_network_client):
        poller = await mock_network_client.network_watchers.begin_get_flow_log_status("rg", "nw", {})
        flow_log = await poller.result()
        assert flow_log.enabled is True

    def test_all_managers_present(self, mock_network_client):
        managers = [
            "network_security_groups",
            "virtual_networks",
            "subnets",
            "route_tables",
            "network_interfaces",
            "public_ip_addresses",
            "virtual_network_peerings",
            "network_watchers",
        ]
        for manager in managers:
            assert hasattr(mock_network_client, manager), f"Missing manager: {manager}"


# =============================================================================
# mock_network_mcp_client fixture
# =============================================================================

class TestMockNetworkMcpClientFixture:
    @pytest.mark.asyncio
    async def test_call_tool_known_tool(self, mock_network_mcp_client):
        result = await mock_network_mcp_client.call_tool(
            "get_nsg_flow_logs", {"resource_group": "test-rg"}
        )
        assert result["success"] is True
        assert "flow_logs" in result["data"]

    @pytest.mark.asyncio
    async def test_call_tool_unknown_tool_returns_success(self, mock_network_mcp_client):
        result = await mock_network_mcp_client.call_tool(
            "some_unknown_tool", {"key": "value"}
        )
        assert result["success"] is True
        assert result["data"]["tool"] == "some_unknown_tool"
        assert result["data"]["arguments"] == {"key": "value"}

    @pytest.mark.asyncio
    async def test_call_tool_list_nsgs(self, mock_network_mcp_client):
        result = await mock_network_mcp_client.call_tool("list_nsgs", {})
        assert result["success"] is True
        assert len(result["data"]["nsgs"]) > 0

    @pytest.mark.asyncio
    async def test_list_tools(self, mock_network_mcp_client):
        tools = await mock_network_mcp_client.list_tools()
        tool_names = [t["name"] for t in tools]
        assert "get_nsg_flow_logs" in tool_names
        assert "test_connectivity" in tool_names
        assert "get_effective_routes" in tool_names

    @pytest.mark.asyncio
    async def test_call_tool_connectivity(self, mock_network_mcp_client):
        result = await mock_network_mcp_client.call_tool(
            "test_connectivity", {"source": "10.0.0.4", "destination": "10.1.0.4"}
        )
        assert result["success"] is True
        assert result["data"]["reachable"] is True


# =============================================================================
# mock_resourcegraph_client fixture
# =============================================================================

class TestMockResourcegraphClientFixture:
    @pytest.mark.asyncio
    async def test_resources_query(self, mock_resourcegraph_client):
        result = await mock_resourcegraph_client.resources(
            "Resources | where type == 'microsoft.network/networksecuritygroups'"
        )
        assert result.total_records == 2
        assert len(result.data) == 2

    @pytest.mark.asyncio
    async def test_result_data_has_expected_fields(self, mock_resourcegraph_client):
        result = await mock_resourcegraph_client.resources("Resources | limit 10")
        for item in result.data:
            assert "id" in item
            assert "name" in item
            assert "type" in item
            assert "location" in item

    @pytest.mark.asyncio
    async def test_includes_nsg_and_vnet(self, mock_resourcegraph_client):
        result = await mock_resourcegraph_client.resources("Resources")
        types = [item["type"] for item in result.data]
        assert "microsoft.network/networksecuritygroups" in types
        assert "microsoft.network/virtualnetworks" in types
