# Section 4: Connectivity matrix generation workflow
# ══════════════════════════════════════════════════════════════════════════════

@pytest.mark.asyncio
class TestConnectivityMatrixWorkflow:
    """
    Integration tests for the generate_connectivity_matrix tool.
    Uses mocked network_client to simulate a 4-VNet / 12-subnet topology.
    """

    async def test_matrix_tool_present_in_server(self):
        """Verify the generate_connectivity_matrix tool is defined in the server."""
        server_path = Path(__file__).parent.parent.parent / "mcp_servers" / "network_mcp_server.py"
        content = server_path.read_text()
        assert "generate_connectivity_matrix" in content
        assert "@_server.tool" in content

    async def test_mock_network_client_returns_vnets(self, mock_network_client):
        """Confirm mock_network_client fixture provides iterable VNets."""
        vnets = [v async for v in mock_network_client.virtual_networks.list("test-rg")]
        assert len(vnets) >= 1
        assert vnets[0].name == "test-vnet-01"

    async def test_topology_has_expected_vnet_count(self):
        """Verify the test topology builder produces exactly 4 VNets."""
        topo = _make_hub_spoke_topology()
        assert len(topo["vnets"]) == 4

    async def test_topology_has_12_subnets_total(self):
        """Verify the 4 VNets together have exactly 12 subnets."""
        topo = _make_hub_spoke_topology()
        total_subnets = sum(len(v.subnets) for v in topo["vnets"])
        assert total_subnets == 12

    async def test_hub_has_three_peerings(self):
        """Hub VNet should have 3 active peerings to spokes."""
        topo = _make_hub_spoke_topology()
        hub_vnet = topo["vnets"][0]
        assert len(hub_vnet.virtual_network_peerings) == 3
        for p in hub_vnet.virtual_network_peerings:
            assert p.peering_state == "Connected"


# ══════════════════════════════════════════════════════════════════════════════
# Section 5: Hub-spoke topology validation workflow
# ══════════════════════════════════════════════════════════════════════════════

@pytest.mark.asyncio
class TestHubSpokeTopologyValidation:
    """
    Integration tests for hub-spoke topology validation workflows.
    Verifies peering states, spoke isolation, and tool presence.
    """

    async def test_hub_spoke_tool_present_in_server(self):
        """Verify validate_hub_spoke_topology tool is defined in the server."""
        server_path = Path(__file__).parent.parent.parent / "mcp_servers" / "network_mcp_server.py"
        content = server_path.read_text()
        assert "validate_hub_spoke_topology" in content

    async def test_all_peerings_connected(self):
        """All hub↔spoke peerings in the test topology are Connected."""
        topo = _make_hub_spoke_topology()
        for peering in topo["peerings"]:
            assert peering.peering_state == "Connected", (
                f"Peering {peering.name} should be Connected"
            )

    async def test_spoke_vnet_peering_targets_hub(self):
        """Each spoke VNet has exactly one peering pointing back to the hub."""
        topo = _make_hub_spoke_topology()
        hub_vnet = topo["vnets"][0]
        for spoke_vnet in topo["vnets"][1:]:  # spoke1, spoke2, spoke3
            assert len(spoke_vnet.virtual_network_peerings) == 1
            peering = spoke_vnet.virtual_network_peerings[0]
            assert peering.remote_virtual_network.id == hub_vnet.id

    async def test_spoke_isolation_no_direct_peering(self):
        """Spokes must NOT have direct peerings to each other (traffic via hub only)."""
        topo = _make_hub_spoke_topology()
        spoke_ids = {v.id for v in topo["vnets"][1:]}

        for spoke_vnet in topo["vnets"][1:]:
            for peering in spoke_vnet.virtual_network_peerings:
                remote_id = peering.remote_virtual_network.id
                assert remote_id not in spoke_ids, (
                    f"Spoke {spoke_vnet.name} has direct peering to another spoke — "
                    "violates hub-spoke isolation requirement"
                )

    async def test_disconnected_peering_detected(self):
        """A Disconnected peering should be identifiable as a topology violation."""
        topo = _make_hub_spoke_topology()
        # Simulate spoke3's peering going Disconnected
        topo["vnets"][3].virtual_network_peerings[0].peering_state = "Disconnected"

        disconnected = [
            v.name
            for v in topo["vnets"]
            for p in v.virtual_network_peerings
            if p.peering_state != "Connected"
        ]
        assert "spoke3-vnet" in disconnected


# ══════════════════════════════════════════════════════════════════════════════
# Section 6: Systematic troubleshooting workflow (route + NSG coordinated)
# ══════════════════════════════════════════════════════════════════════════════

class TestSystematicTroubleshootingWorkflow:
    """
    Simulates the workflow an agent would use when troubleshooting connectivity:
    1. Evaluate NSG rules for the flow
    2. Cross-reference with routing information
    3. Surface combined diagnosis
    """

    def test_blocked_at_nsg_before_routing(self):
        """
        When NSG denies a flow, routing analysis is unnecessary.
        Verify that Deny verdict is decisive and evaluation stops early.
        """
        rules = [
            NSGRule("deny-unknown-port", 100, "Deny", "Inbound", "*", "*", "9999", "TCP"),
            NSGRule("allow-all", 200, "Allow", "Inbound", "*", "*", "*", "*"),
        ]
        flow = FlowTuple("10.0.0.1", "10.1.2.3", 9999, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)

        # Deny at rule 100 — evaluation chain stops at 1 entry
        assert verdict.action == "Deny"
        assert len(verdict.evaluation_chain) == 1
        assert verdict.evaluation_chain[0]["rule_name"] == "deny-unknown-port"

    def test_allowed_at_nsg_continue_to_routing(self):
        """
        When NSG allows traffic, routing is the next check.
        Verify verdict is Allow so agent knows to proceed to route analysis.
        """
        rules = [NSGRule("allow-all", 100, "Allow", "Inbound", "*", "*", "*", "*")]
        flow = FlowTuple("10.0.0.1", "10.1.2.3", 443, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == "Allow"
        # Agent would now call analyze_route_path

    def test_multi_step_diagnosis_both_tools_invocable(self):
        """Verify both simulate_nsg_flow and analyze_route_path are present in server."""
        server_path = Path(__file__).parent.parent.parent / "mcp_servers" / "network_mcp_server.py"
        content = server_path.read_text()
        assert "simulate_nsg_flow" in content
        assert "analyze_route_path" in content

    def test_rdp_troubleshooting_workflow(self):
        """
        Full RDP troubleshooting scenario:
        - External IP → VM on port 3389
        - NSG has: allow-all-tcp(200) + deny-rdp-internet(100)
        - Expected: Deny at rule 100, recommendation to use JIT
        """
        rules = [
            NSGRule("deny-rdp-internet", 100, "Deny",  "Inbound",
                    "Internet", "*", "3389", "TCP"),
            NSGRule("allow-all-tcp",     200, "Allow", "Inbound",
                    "*", "*", "*", "TCP"),
        ]
        flow = FlowTuple("203.0.113.10", "10.1.2.3", 3389, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)

        assert verdict.action == "Deny"
        assert verdict.matched_rule.name == "deny-rdp-internet"
        # Deny verdict → no recommendations (rule is intentionally restrictive)
        assert verdict.recommendations == []

    def test_missing_nsg_fallback_to_default_deny(self):
        """Empty rules list represents an NSG with no custom rules → DefaultDeny."""
        flow = FlowTuple("10.0.0.1", "10.1.2.3", 443, "TCP")
        verdict = _evaluator.evaluate_flow([], flow)
        assert verdict.action == "DefaultDeny"
        assert verdict.evaluation_chain == []

    @pytest.mark.parametrize("src_ip,port,expected", [
        # Internal management access from hub mgmt subnet (10.0.2.x) — allowed
        ("10.0.2.5", 22,   "Allow"),
        # Internet SSH — deny-mgmt-internet (Internet tag) matches 8.8.8.8 → Deny
        ("8.8.8.8",  22,   "Deny"),
        # Internal HTTPS from VirtualNetwork — allowed
        ("10.2.3.4", 443,  "Allow"),
        # Internal RDP from hub mgmt subnet — allowed
        ("10.0.2.5", 3389, "Allow"),
        # Internal IP NOT in mgmt subnet, not HTTPS → DefaultDeny
        ("10.0.0.4", 22,   "DefaultDeny"),
    ])
    def test_parameterized_management_access(self, src_ip, port, expected):
        """Parametrized management-port scenarios for a typical hub-connected VM NSG."""
        rules = [
            # Allow management protocols from hub management subnet
            NSGRule("allow-mgmt-hub", 100, "Allow", "Inbound",
                    "10.0.2.0/24", "*", "22,3389,5985,5986", "TCP"),
            # Allow HTTPS from VirtualNetwork
            NSGRule("allow-https-vnet", 110, "Allow", "Inbound",
                    "VirtualNetwork", "*", "443", "TCP"),
            # Block internet access to management ports
            NSGRule("deny-mgmt-internet", 200, "Deny", "Inbound",
                    "Internet", "*", "22,3389,5985,5986", "TCP"),
        ]
        flow = FlowTuple(src_ip, "10.1.2.3", port, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == expected, (
            f"src={src_ip} port={port}: expected {expected}, got {verdict.action}\n"
            f"chain: {verdict.evaluation_chain}"
        )


# ══════════════════════════════════════════════════════════════════════════════
# Section 7: Error handling
# ══════════════════════════════════════════════════════════════════════════════

@pytest.mark.asyncio
class TestErrorHandling:
    """
    Integration tests verifying graceful error handling:
    - Network Watcher unavailable
    - Permission denied (AuthorizationFailed)
    - NSG not found
    - Malformed inputs
    """

    async def test_missing_azure_sdk_returns_error(self):
        """When azure-mgmt-network is not installed, tool returns structured error."""
        from mcp_servers import network_mcp_server

        original = network_mcp_server.NetworkManagementClient
        try:
            network_mcp_server.NetworkManagementClient = None
            from mcp_servers.network_mcp_server import simulate_nsg_flow
            mock_ctx = MagicMock()
            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                source_ip="10.0.0.1",
                destination_ip="10.0.1.5",
                destination_port=443,
                nsg_id="test-rg/test-nsg",
            )
            data = json.loads(result_content[0].text)
            assert data["success"] is False
            assert "azure-mgmt-network" in data["error"]
        finally:
            network_mcp_server.NetworkManagementClient = original

    async def test_permission_denied_nsg_fetch(self):
        """AuthorizationFailed from Azure SDK returns structured error with NSG context."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow

        mock_ctx = MagicMock()

        def _raise_auth_error(*args, **kwargs):
            raise PermissionError("AuthorizationFailed: client does not have authorization")

        with patch("mcp_servers.network_mcp_server._get_credential", return_value=MagicMock()), \
             patch("mcp_servers.network_mcp_server._get_subscription_id", return_value="test-sub"), \
             patch("mcp_servers.network_mcp_server.NetworkManagementClient") as mock_nmc:

            mock_client_instance = MagicMock()
            mock_client_instance.network_security_groups.get = _raise_auth_error
            mock_nmc.return_value = mock_client_instance

            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                subscription_id="test-sub",
                source_ip="10.0.0.1",
                destination_ip="10.0.1.5",
                destination_port=443,
                nsg_id="prod-rg/prod-nsg",
            )

        data = json.loads(result_content[0].text)
        assert data["success"] is False
        assert "prod-nsg" in data.get("nsg_name", "") or "AuthorizationFailed" in data.get("error", "")

    async def test_empty_rules_nsg_returns_default_deny(self):
        """NSG with zero rules (empty security_rules list) returns DefaultDeny."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow

        nsg_obj = MagicMock()
        nsg_obj.security_rules = []
        nsg_obj.default_security_rules = []
        mock_ctx = MagicMock()

        with patch("mcp_servers.network_mcp_server._get_credential", return_value=MagicMock()), \
             patch("mcp_servers.network_mcp_server._get_subscription_id", return_value="test-sub"), \
             patch("mcp_servers.network_mcp_server.NetworkManagementClient") as mock_nmc:

            mock_client_instance = MagicMock()
            mock_client_instance.network_security_groups.get = MagicMock(return_value=nsg_obj)
            mock_nmc.return_value = mock_client_instance

            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                subscription_id="test-sub",
                source_ip="10.0.0.1",
                destination_ip="10.0.1.5",
                destination_port=443,
                nsg_id="test-rg/test-nsg",
            )

        data = json.loads(result_content[0].text)
        assert data["success"] is True
        assert data["verdict"] == "DefaultDeny"
        assert data["rules_evaluated"] == 0

    async def test_no_nsg_auto_detect_returns_structured_error(self):
        """When auto-detect finds no NSG for the IP, error includes flow context."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow
        import mcp_servers.network_mcp_server as _srv

        mock_ctx = MagicMock()

        # Mock CLI executor returning empty vnet list (no subnets to match)
        mock_executor = AsyncMock()
        mock_executor.execute = AsyncMock(return_value={
            "status": "success",
            "output": [],  # no VNets → no subnets → no NSG match
        })

        # Ensure NetworkManagementClient is truthy so the SDK-check guard is bypassed
        original_nmc = _srv.NetworkManagementClient
        try:
            if _srv.NetworkManagementClient is None:
                _srv.NetworkManagementClient = MagicMock()

            with patch("mcp_servers.network_mcp_server._get_credential", return_value=MagicMock()), \
                 patch("mcp_servers.network_mcp_server._get_subscription_id", return_value="test-sub"), \
                 patch("mcp_servers.network_mcp_server.get_azure_cli_executor",
                       return_value=mock_executor):

                result_content = await simulate_nsg_flow(
                    context=mock_ctx,
                    subscription_id="test-sub",
                    source_ip="192.168.99.1",
                    destination_ip="192.168.99.50",
                    destination_port=443,
                    # nsg_id intentionally omitted to trigger auto-detect
                )
        finally:
            _srv.NetworkManagementClient = original_nmc

        data = json.loads(result_content[0].text)
        assert data["success"] is False
        assert "auto-detect" in data["error"].lower() or "nsg" in data["error"].lower()
        # Flow context should be present in error response
        assert data.get("destination_port") == 443

    async def test_malformed_nsg_rule_skipped_gracefully(self):
        """Rules missing required fields are skipped; valid rules still evaluated."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow

        # Build NSG: one bad rule (no priority) + one good rule
        bad_rule = MagicMock()
        bad_rule.name = "bad-rule"
        bad_rule.priority = None  # missing required field
        bad_rule.access = "Allow"
        bad_rule.direction = "Inbound"
        bad_rule.protocol = "Tcp"
        bad_rule.source_address_prefix = "*"
        bad_rule.destination_address_prefix = "*"
        bad_rule.destination_port_range = "443"

        good_rule = MagicMock()
        good_rule.name = "allow-https"
        good_rule.priority = 200
        good_rule.access = "Allow"
        good_rule.direction = "Inbound"
        good_rule.protocol = "Tcp"
        good_rule.source_address_prefix = "*"
        good_rule.destination_address_prefix = "*"
        good_rule.destination_port_range = "443"
        good_rule.description = None

        nsg_obj = MagicMock()
        nsg_obj.security_rules = [bad_rule, good_rule]
        nsg_obj.default_security_rules = []
        mock_ctx = MagicMock()

        with patch("mcp_servers.network_mcp_server._get_credential", return_value=MagicMock()), \
             patch("mcp_servers.network_mcp_server._get_subscription_id", return_value="test-sub"), \
             patch("mcp_servers.network_mcp_server.NetworkManagementClient") as mock_nmc:

            mock_client_instance = MagicMock()
            mock_client_instance.network_security_groups.get = MagicMock(return_value=nsg_obj)
            mock_nmc.return_value = mock_client_instance

            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                subscription_id="test-sub",
                source_ip="10.0.0.1",
                destination_ip="10.0.1.5",
                destination_port=443,
                nsg_id="test-rg/test-nsg",
            )

        data = json.loads(result_content[0].text)
        # Bad rule was skipped, good rule evaluated → Allow
        assert data["success"] is True
        assert data["verdict"] == "Allow"


# ══════════════════════════════════════════════════════════════════════════════
# Section 8: _parse_azure_nsg_rule helper unit tests
# ══════════════════════════════════════════════════════════════════════════════

class TestParseAzureNsgRule:
    """Unit tests for the _parse_azure_nsg_rule helper in network_mcp_server."""

    def _make_raw_rule(self, **kwargs) -> MagicMock:
        rule = MagicMock()
        rule.name = kwargs.get("name", "test-rule")
        rule.priority = kwargs.get("priority", 100)
        rule.access = kwargs.get("access", "Allow")
        rule.direction = kwargs.get("direction", "Inbound")
        rule.protocol = kwargs.get("protocol", "Tcp")
        rule.source_address_prefix = kwargs.get("source_address_prefix", "*")
        rule.destination_address_prefix = kwargs.get("destination_address_prefix", "*")
        rule.destination_port_range = kwargs.get("destination_port_range", "443")
        rule.description = kwargs.get("description", None)
        return rule

    def test_basic_rule_parsed_correctly(self):
        from mcp_servers.network_mcp_server import _parse_azure_nsg_rule
        raw = self._make_raw_rule()
        result = _parse_azure_nsg_rule(raw)
        assert result is not None
        assert result.name == "test-rule"
        assert result.priority == 100
        assert result.action == "Allow"
        assert result.direction == "Inbound"
        assert result.protocol == "Tcp"

    def test_enum_style_access_stripped(self):
        from mcp_servers.network_mcp_server import _parse_azure_nsg_rule
        raw = self._make_raw_rule(
            access="SecurityRuleAccess.Deny",
            direction="SecurityRuleDirection.Outbound",
            protocol="SecurityRuleProtocol.Udp",
        )
        result = _parse_azure_nsg_rule(raw)
        assert result.action == "Deny"
        assert result.direction == "Outbound"
        assert result.protocol == "Udp"

    def test_missing_priority_returns_none(self):
        from mcp_servers.network_mcp_server import _parse_azure_nsg_rule
        raw = self._make_raw_rule(priority=None)
        result = _parse_azure_nsg_rule(raw)
        assert result is None

    def test_missing_name_returns_none(self):
        from mcp_servers.network_mcp_server import _parse_azure_nsg_rule
        raw = self._make_raw_rule(name=None)
        result = _parse_azure_nsg_rule(raw)
        assert result is None

    def test_none_prefix_defaults_to_wildcard(self):
        from mcp_servers.network_mcp_server import _parse_azure_nsg_rule
        raw = self._make_raw_rule(source_address_prefix=None, destination_address_prefix=None)
        result = _parse_azure_nsg_rule(raw)
        assert result is not None
        assert result.source_address_prefix == "*"
        assert result.dest_address_prefix == "*"
