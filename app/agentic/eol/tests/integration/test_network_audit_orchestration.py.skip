"""
Integration Tests – Network Audit Orchestration

End-to-end workflow tests covering the full network audit pipeline:

1. NSG flow simulation (simulate_nsg_flow) — verdict, evaluation chain, recommendations
2. Route path analysis (analyze_route_path) — LPM tracing, black-hole detection
3. Security posture assessment — multi-NSG audit with known violations
4. Connectivity matrix generation — 4-VNet / 12-subnet topology
5. Hub-spoke topology validation — peering state, spoke isolation
6. Systematic troubleshooting workflow — coordinated route + NSG analysis
7. Error handling — Network Watcher unavailable, permission denied, missing NSG

All Azure SDK dependencies are mocked with AsyncMock / MagicMock following the
patterns established in tests/conftest.py.  No live Azure credentials are required.

Run with:
    pytest tests/integration/test_network_audit_orchestration.py -v
    pytest tests/integration/test_network_audit_orchestration.py -v -k "nsg"
"""

from __future__ import annotations

import asyncio
import json
import sys
import os
import pytest
from pathlib import Path
from typing import Any, Dict, List, Optional
from unittest.mock import AsyncMock, MagicMock, patch, call

# Ensure the app root is on sys.path for absolute imports
_APP_ROOT = str(Path(__file__).parent.parent.parent)
if _APP_ROOT not in sys.path:
    sys.path.insert(0, _APP_ROOT)

from tests.conftest import (
    factory_make_nsg,
    factory_make_vnet,
    factory_make_subnet,
    factory_make_routetable,
    factory_make_nic,
    factory_make_vnet_peering,
)
from utils.nsg_rule_evaluator import FlowTuple, NSGRule, NSGRuleEvaluator, RuleVerdict

# ---------------------------------------------------------------------------
# Stub the 'mcp' package so network_mcp_server can be imported in test
# environments that don't have the full MCP runtime installed.
# ---------------------------------------------------------------------------
import types as _types

def _stub_mcp():
    """Insert minimal mcp stubs into sys.modules if not already present."""
    if "mcp" in sys.modules:
        return

    # mcp top-level
    mcp_mod = _types.ModuleType("mcp")
    sys.modules["mcp"] = mcp_mod

    # mcp.types
    mcp_types = _types.ModuleType("mcp.types")
    class TextContent:  # noqa: N801
        def __init__(self, *, type: str, text: str):
            self.type = type
            self.text = text
    mcp_types.TextContent = TextContent
    sys.modules["mcp.types"] = mcp_types
    mcp_mod.types = mcp_types

    # mcp.server
    mcp_server = _types.ModuleType("mcp.server")
    sys.modules["mcp.server"] = mcp_server

    # mcp.server.fastmcp
    fastmcp_mod = _types.ModuleType("mcp.server.fastmcp")

    class _FakeFastMCP:
        def __init__(self, name: str = ""):
            self.name = name
        def tool(self):
            def _decorator(fn):
                return fn
            return _decorator
        def run(self, transport: str = "stdio"):
            pass

    class _FakeContext:
        pass

    fastmcp_mod.FastMCP = _FakeFastMCP
    fastmcp_mod.Context = _FakeContext
    sys.modules["mcp.server.fastmcp"] = fastmcp_mod
    mcp_server.fastmcp = fastmcp_mod

    # mcp.client / mcp.client.stdio (used in network_mcp_client)
    mcp_client = _types.ModuleType("mcp.client")
    mcp_client_stdio = _types.ModuleType("mcp.client.stdio")
    mcp_client_stdio.stdio_client = None
    sys.modules["mcp.client"] = mcp_client
    sys.modules["mcp.client.stdio"] = mcp_client_stdio
    mcp_mod.client = mcp_client

    # mcp.ClientSession / StdioServerParameters (imported in network_mcp_client.py)
    mcp_mod.ClientSession = MagicMock
    mcp_mod.StdioServerParameters = MagicMock

_stub_mcp()


# ── module-level evaluator (stateless) ───────────────────────────────────────
_evaluator = NSGRuleEvaluator()


# ══════════════════════════════════════════════════════════════════════════════
# Section 0: Test topology helpers
# ══════════════════════════════════════════════════════════════════════════════

def _make_hub_spoke_topology():
    """
    Build a 4-VNet / 12-subnet hub-spoke test topology.

    Returns dict with:
      vnets    : hub + 3 spoke VNets (each with 3 subnets)
      nsgs     : one NSG per spoke VNet
      peerings : hub ↔ spoke1, hub ↔ spoke2, hub ↔ spoke3
    """
    # ---- NSGs ----------------------------------------------------------------
    nsg_spoke1 = factory_make_nsg(
        "nsg-spoke1",
        "/subscriptions/test-sub/resourceGroups/test-rg/providers/Microsoft.Network/networkSecurityGroups/nsg-spoke1",
        "eastus",
        rules_list=[
            {"name": "allow-https", "priority": 100, "direction": "Inbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "10.0.0.0/8",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "443"},
            {"name": "deny-rdp-internet", "priority": 200, "direction": "Inbound",
             "access": "Deny", "protocol": "Tcp", "source_address_prefix": "Internet",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "3389"},
        ],
    )
    nsg_spoke1.default_security_rules = []

    nsg_spoke2 = factory_make_nsg(
        "nsg-spoke2",
        "/subscriptions/test-sub/resourceGroups/test-rg/providers/Microsoft.Network/networkSecurityGroups/nsg-spoke2",
        "eastus",
        rules_list=[
            # Over-permissive: allows ALL inbound from Internet on port 22
            {"name": "allow-ssh-internet", "priority": 100, "direction": "Inbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "22"},
        ],
    )
    nsg_spoke2.default_security_rules = []

    nsg_spoke3 = factory_make_nsg(
        "nsg-spoke3",
        "/subscriptions/test-sub/resourceGroups/test-rg/providers/Microsoft.Network/networkSecurityGroups/nsg-spoke3",
        "eastus",
        rules_list=[
            {"name": "deny-all-inbound", "priority": 100, "direction": "Inbound",
             "access": "Deny", "protocol": "*", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "*"},
        ],
    )
    nsg_spoke3.default_security_rules = []

    # ---- subnets -------------------------------------------------------------
    def _subnets(prefix_16: str, spoke_nsg):
        return [
            factory_make_subnet(f"web-{prefix_16.replace('.', '-')}", f"{prefix_16.rsplit('.', 1)[0]}.1.0/24", nsg=spoke_nsg),
            factory_make_subnet(f"app-{prefix_16.replace('.', '-')}", f"{prefix_16.rsplit('.', 1)[0]}.2.0/24", nsg=spoke_nsg),
            factory_make_subnet(f"db-{prefix_16.replace('.', '-')}",  f"{prefix_16.rsplit('.', 1)[0]}.3.0/24"),
        ]

    hub_subnets = [
        factory_make_subnet("GatewaySubnet", "10.0.0.0/27"),
        factory_make_subnet("AzureFirewallSubnet", "10.0.1.0/26"),
        factory_make_subnet("management", "10.0.2.0/24"),
    ]
    spoke1_subnets = _subnets("10.1.0.0", nsg_spoke1)
    spoke2_subnets = _subnets("10.2.0.0", nsg_spoke2)
    spoke3_subnets = _subnets("10.3.0.0", nsg_spoke3)

    # ---- VNets ---------------------------------------------------------------
    hub_vnet   = factory_make_vnet("hub-vnet",   ["10.0.0.0/16"], "eastus", subnets=hub_subnets)
    spoke1_vnet = factory_make_vnet("spoke1-vnet", ["10.1.0.0/16"], "eastus", subnets=spoke1_subnets)
    spoke2_vnet = factory_make_vnet("spoke2-vnet", ["10.2.0.0/16"], "eastus", subnets=spoke2_subnets)
    spoke3_vnet = factory_make_vnet("spoke3-vnet", ["10.3.0.0/16"], "eastus", subnets=spoke3_subnets)

    # ---- peerings ------------------------------------------------------------
    p_hub_to_s1 = factory_make_vnet_peering("hub-to-spoke1", spoke1_vnet.id)
    p_hub_to_s2 = factory_make_vnet_peering("hub-to-spoke2", spoke2_vnet.id)
    p_hub_to_s3 = factory_make_vnet_peering("hub-to-spoke3", spoke3_vnet.id)
    p_s1_to_hub = factory_make_vnet_peering("spoke1-to-hub", hub_vnet.id)
    p_s2_to_hub = factory_make_vnet_peering("spoke2-to-hub", hub_vnet.id)
    p_s3_to_hub = factory_make_vnet_peering("spoke3-to-hub", hub_vnet.id)

    hub_vnet.virtual_network_peerings = [p_hub_to_s1, p_hub_to_s2, p_hub_to_s3]
    spoke1_vnet.virtual_network_peerings = [p_s1_to_hub]
    spoke2_vnet.virtual_network_peerings = [p_s2_to_hub]
    spoke3_vnet.virtual_network_peerings = [p_s3_to_hub]

    return {
        "vnets":    [hub_vnet, spoke1_vnet, spoke2_vnet, spoke3_vnet],
        "nsgs":     [nsg_spoke1, nsg_spoke2, nsg_spoke3],
        "peerings": [p_hub_to_s1, p_hub_to_s2, p_hub_to_s3],
    }


def _make_nsg_obj_mock(rules_list: List[Dict[str, Any]]) -> MagicMock:
    """
    Build a MagicMock that looks like ``NetworkManagementClient.network_security_groups.get()``
    returns — i.e. an NSG object with ``.security_rules`` and ``.default_security_rules``.
    """
    nsg_id = "/subscriptions/test-sub/resourceGroups/test-rg/providers/Microsoft.Network/networkSecurityGroups/test-nsg"
    obj = factory_make_nsg("test-nsg", nsg_id, "eastus", rules_list=rules_list)
    obj.default_security_rules = []
    return obj


