# Section 1: NSGRuleEvaluator unit-level integration
# ══════════════════════════════════════════════════════════════════════════════

class TestNSGEvaluatorIntegration:
    """
    Integration tests for NSGRuleEvaluator using realistic rule sets.
    No Azure mocks needed – pure logic.
    """

    def test_allow_https_from_private_network(self):
        """VirtualNetwork tag allows HTTPS from private IPs."""
        rules = [
            NSGRule("allow-internal-https", 100, "Allow", "Inbound",
                    "VirtualNetwork", "*", "443", "TCP"),
            NSGRule("deny-all", 4096, "Deny", "Inbound",
                    "*", "*", "*", "*"),
        ]
        flow = FlowTuple("10.5.10.20", "10.1.2.3", 443, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == "Allow"
        assert verdict.matched_rule.name == "allow-internal-https"

    def test_deny_internet_ssh(self):
        """Internet-sourced SSH is denied by explicit rule."""
        rules = [
            NSGRule("deny-ssh-internet", 100, "Deny", "Inbound",
                    "Internet", "*", "22", "TCP"),
        ]
        flow = FlowTuple("8.8.8.8", "10.1.2.3", 22, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == "Deny"
        assert verdict.matched_rule.name == "deny-ssh-internet"

    def test_default_deny_when_no_match(self):
        """Traffic on unlisted port falls through to DefaultDeny."""
        rules = [
            NSGRule("allow-https", 100, "Allow", "Inbound", "*", "*", "443", "TCP"),
        ]
        flow = FlowTuple("10.0.0.1", "10.1.2.3", 8080, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == "DefaultDeny"
        assert verdict.matched_rule is None

    def test_priority_ordering_with_overlapping_rules(self):
        """Lower-priority-number rule wins even when a later Allow rule also matches."""
        rules = [
            NSGRule("allow-all-tcp", 200, "Allow", "Inbound", "*", "*", "*", "TCP"),
            NSGRule("deny-rdp",      100, "Deny",  "Inbound", "*", "*", "3389", "TCP"),
        ]
        flow = FlowTuple("203.0.113.5", "10.1.2.3", 3389, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == "Deny"
        assert verdict.matched_rule.name == "deny-rdp"

    def test_evaluation_chain_covers_all_non_matching_rules(self):
        """Evaluation chain should contain entries for every rule examined before match."""
        rules = [
            NSGRule("allow-443", 100, "Allow", "Inbound", "*", "*", "443", "TCP"),
            NSGRule("allow-80",  200, "Allow", "Inbound", "*", "*", "80",  "TCP"),
            NSGRule("deny-all",  300, "Deny",  "Inbound", "*", "*", "*",   "*"),
        ]
        flow = FlowTuple("10.0.0.1", "10.1.2.3", 80, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        # allow-443 didn't match, allow-80 did → chain stops at 2 entries
        assert len(verdict.evaluation_chain) == 2
        assert verdict.evaluation_chain[0]["matched"] is False   # allow-443
        assert verdict.evaluation_chain[1]["matched"] is True    # allow-80

    def test_recommendations_for_overpermissive_ssh_rule(self):
        """Over-permissive SSH rule produces both source and management-port recommendations."""
        rules = [
            NSGRule("allow-all-ssh", 100, "Allow", "Inbound",
                    "*", "*", "22", "TCP"),
        ]
        flow = FlowTuple("8.8.8.8", "10.1.2.3", 22, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert verdict.action == "Allow"
        assert any("Restrict source" in r for r in verdict.recommendations)
        assert any("22" in r and "JIT" in r for r in verdict.recommendations)

    def test_wildcard_protocol_recommendation(self):
        """Wildcard protocol on allow rule triggers protocol-specificity recommendation."""
        rules = [NSGRule("allow-all", 100, "Allow", "Inbound", "*", "*", "*", "*")]
        flow = FlowTuple("10.0.0.1", "10.1.2.3", 80, "TCP")
        verdict = _evaluator.evaluate_flow(rules, flow)
        assert any("explicit protocols" in r.lower() or "wildcard protocol" in r.lower()
                   for r in verdict.recommendations)


