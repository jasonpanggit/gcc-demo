# Section 2: simulate_nsg_flow MCP tool integration
# ══════════════════════════════════════════════════════════════════════════════

@pytest.mark.asyncio
class TestSimulateNSGFlowTool:
    """
    Integration tests for the simulate_nsg_flow MCP tool function.

    Patches:
    - azure.mgmt.network.NetworkManagementClient  (via _get_credential / run_in_executor)
    - utils.azure_cli_executor.get_azure_cli_executor (for auto-detect path)
    """

    async def _call_simulate(
        self,
        nsg_obj: MagicMock,
        source_ip: str = "10.1.2.3",
        destination_ip: str = "10.0.1.5",
        destination_port: int = 443,
        protocol: str = "TCP",
        direction: str = "Inbound",
        nsg_id: str = "test-rg/test-nsg",
    ) -> Dict[str, Any]:
        """Helper: call simulate_nsg_flow with mocked Azure SDK."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow

        mock_ctx = MagicMock()

        def _sync_get_nsg(*args, **kwargs):
            return nsg_obj

        with patch("mcp_servers.network_mcp_server._get_credential", return_value=MagicMock()), \
             patch("mcp_servers.network_mcp_server._get_subscription_id", return_value="test-sub"), \
             patch("mcp_servers.network_mcp_server.NetworkManagementClient") as mock_nmc:

            # Synchronous .get call happens inside run_in_executor; wire it directly
            mock_client_instance = MagicMock()
            mock_client_instance.network_security_groups.get = _sync_get_nsg
            mock_nmc.return_value = mock_client_instance

            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                subscription_id="test-sub",
                source_ip=source_ip,
                destination_ip=destination_ip,
                destination_port=destination_port,
                protocol=protocol,
                direction=direction,
                nsg_id=nsg_id,
            )

        assert result_content, "Tool returned empty content"
        return json.loads(result_content[0].text)

    async def test_allow_verdict_https(self):
        """HTTPS traffic from internal IP is Allowed by matching rule."""
        nsg_obj = _make_nsg_obj_mock([
            {"name": "allow-https", "priority": 100, "direction": "Inbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "10.0.0.0/8",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "443"},
        ])
        result = await self._call_simulate(nsg_obj, destination_port=443, source_ip="10.5.6.7")
        assert result["success"] is True
        assert result["verdict"] == "Allow"
        assert result["matched_rule"]["name"] == "allow-https"

    async def test_deny_verdict_rdp(self):
        """RDP traffic explicitly Denied by priority-100 rule."""
        nsg_obj = _make_nsg_obj_mock([
            {"name": "deny-rdp", "priority": 100, "direction": "Inbound",
             "access": "Deny", "protocol": "Tcp", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "3389"},
        ])
        result = await self._call_simulate(nsg_obj, destination_port=3389)
        assert result["success"] is True
        assert result["verdict"] == "Deny"

    async def test_default_deny_no_matching_rule(self):
        """Traffic on port 8080 returns DefaultDeny when no rule covers it."""
        nsg_obj = _make_nsg_obj_mock([
            {"name": "allow-https", "priority": 100, "direction": "Inbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "443"},
        ])
        result = await self._call_simulate(nsg_obj, destination_port=8080)
        assert result["success"] is True
        assert result["verdict"] == "DefaultDeny"
        assert result["matched_rule"] is None

    async def test_evaluation_chain_in_response(self):
        """Response evaluation_chain lists rules in priority order with matched flag."""
        nsg_obj = _make_nsg_obj_mock([
            {"name": "allow-https", "priority": 100, "direction": "Inbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "443"},
            {"name": "deny-all", "priority": 200, "direction": "Inbound",
             "access": "Deny", "protocol": "*", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "*"},
        ])
        result = await self._call_simulate(nsg_obj, destination_port=443)
        chain = result["evaluation_chain"]
        assert len(chain) >= 1
        assert chain[0]["rule_name"] == "allow-https"
        assert chain[0]["matched"] is True

    async def test_recommendations_for_overpermissive_rule(self):
        """Over-permissive wildcard-source SSH rule generates recommendations."""
        nsg_obj = _make_nsg_obj_mock([
            {"name": "allow-all-ssh", "priority": 100, "direction": "Inbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "*",
             "destination_address_prefix": "*", "source_port_range": "*",
             "destination_port_range": "22"},
        ])
        result = await self._call_simulate(
            nsg_obj, destination_port=22, source_ip="8.8.8.8"
        )
        assert result["verdict"] == "Allow"
        assert result["recommendation_count"] >= 2
        assert any("Restrict source" in r for r in result["recommendations"])
        assert any("JIT" in r for r in result["recommendations"])

    async def test_missing_source_ip_returns_error(self):
        """Tool returns structured error when source_ip is empty."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow
        import mcp_servers.network_mcp_server as _srv

        mock_ctx = MagicMock()
        # Ensure NetworkManagementClient is truthy so the SDK-check guard is bypassed
        original_nmc = _srv.NetworkManagementClient
        try:
            if _srv.NetworkManagementClient is None:
                _srv.NetworkManagementClient = MagicMock()

            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                source_ip="",
                destination_ip="10.0.0.5",
                destination_port=443,
            )
        finally:
            _srv.NetworkManagementClient = original_nmc

        data = json.loads(result_content[0].text)
        assert data["success"] is False
        assert "source_ip" in data["error"].lower() or "required" in data["error"].lower()

    async def test_nsg_fetch_failure_returns_error(self):
        """If NSG cannot be retrieved, tool returns structured error with NSG identity."""
        from mcp_servers.network_mcp_server import simulate_nsg_flow

        mock_ctx = MagicMock()

        def _raise_not_found(*args, **kwargs):
            raise RuntimeError("ResourceNotFound: NSG not found")

        with patch("mcp_servers.network_mcp_server._get_credential", return_value=MagicMock()), \
             patch("mcp_servers.network_mcp_server._get_subscription_id", return_value="test-sub"), \
             patch("mcp_servers.network_mcp_server.NetworkManagementClient") as mock_nmc:

            mock_client_instance = MagicMock()
            mock_client_instance.network_security_groups.get = _raise_not_found
            mock_nmc.return_value = mock_client_instance

            result_content = await simulate_nsg_flow(
                context=mock_ctx,
                subscription_id="test-sub",
                source_ip="10.0.0.1",
                destination_ip="10.0.1.5",
                destination_port=443,
                nsg_id="test-rg/nonexistent-nsg",
            )

        data = json.loads(result_content[0].text)
        assert data["success"] is False
        assert "nonexistent-nsg" in data["error"]

    async def test_outbound_direction_evaluates_correctly(self):
        """Outbound rules are evaluated for Outbound direction request."""
        nsg_obj = _make_nsg_obj_mock([
            {"name": "allow-outbound-https", "priority": 100, "direction": "Outbound",
             "access": "Allow", "protocol": "Tcp", "source_address_prefix": "*",
             "destination_address_prefix": "Internet", "source_port_range": "*",
             "destination_port_range": "443"},
        ])
        result = await self._call_simulate(
            nsg_obj,
            source_ip="10.1.2.3",
            destination_ip="52.100.0.1",  # public IP — matches Internet tag
            destination_port=443,
            direction="Outbound",
        )
        assert result["success"] is True
        assert result["verdict"] == "Allow"

    async def test_azure_sdk_enum_coercion(self):
        """Azure SDK enum-style strings ('SecurityRuleAccess.Allow') are coerced correctly."""
        # Simulate the SDK returning enum-prefixed strings
        rule_mock = MagicMock()
        rule_mock.name = "allow-https"
        rule_mock.priority = 100
        rule_mock.access = "SecurityRuleAccess.Allow"   # enum-like string
        rule_mock.direction = "SecurityRuleDirection.Inbound"
        rule_mock.protocol = "SecurityRuleProtocol.Tcp"
        rule_mock.source_address_prefix = "*"
        rule_mock.destination_address_prefix = "*"
        rule_mock.destination_port_range = "443"
        rule_mock.description = None

        nsg_obj = MagicMock()
        nsg_obj.security_rules = [rule_mock]
        nsg_obj.default_security_rules = []

        result = await self._call_simulate(nsg_obj, destination_port=443)
        # After enum stripping: Allow / Inbound / Tcp should parse correctly
        assert result["success"] is True
        assert result["verdict"] == "Allow"

    async def test_flow_details_echoed_in_response(self):
        """Response includes the original flow parameters for traceability."""
        nsg_obj = _make_nsg_obj_mock([])
        result = await self._call_simulate(
            nsg_obj,
            source_ip="10.2.3.4",
            destination_ip="10.5.6.7",
            destination_port=8443,
            protocol="TCP",
        )
        flow = result.get("flow", {})
        assert flow["source_ip"] == "10.2.3.4"
        assert flow["destination_ip"] == "10.5.6.7"
        assert flow["destination_port"] == 8443
        assert flow["protocol"] == "TCP"


